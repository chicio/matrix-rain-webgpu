{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["@webgpu/types"],
    "paths": {
      "@lib": ["../src/index.ts"],
      "@lib/*": ["../src/*"]
    }
  }
}
