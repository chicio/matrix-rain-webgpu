---
import { HeroRain } from '../components/HeroRain';

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>matrix-rain-webgpu</title>
    <style>
      html,
      body {
        margin: 0;
        height: 100%;
        background: #0a0a0a;
        color: #e6ffe6;
        font-family: ui-monospace, 'JetBrains Mono', monospace;
      }
      #bg {
        position: fixed;
        inset: 0;
        z-index: 0;
      }
      #hero {
        position: relative;
        z-index: 1;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        gap: 1.2rem;
        padding: 2rem;
        pointer-events: none;
      }
      h1 {
        font-size: clamp(2rem, 6vw, 4rem);
        margin: 0;
        text-shadow: 0 0 12px rgba(0, 255, 65, 0.5);
      }
      p {
        opacity: 0.85;
        max-width: 46ch;
        line-height: 1.5;
      }
      .cta {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        justify-content: center;
        pointer-events: auto;
      }
      a.btn {
        border: 1px solid #00ff41;
        color: #00ff41;
        padding: 0.6rem 1.1rem;
        border-radius: 6px;
        text-decoration: none;
        background: rgba(0, 0, 0, 0.4);
      }
      a.btn:hover {
        background: rgba(0, 255, 65, 0.15);
      }
    </style>
  </head>
  <body>
    <div id="bg"><HeroRain client:only="react" /></div>
    <main id="hero">
      <h1>matrix-rain-webgpu</h1>
      <p>A WebGPU Matrix-rain background effect for React — built with TypeGPU.</p>
      <div class="cta">
        <a class="btn" href={`${base}overview/introduction/`}>Docs</a>
        <a class="btn" href={`${base}playground`} target="_blank" rel="noopener">Playground ▸</a>
      </div>
    </main>
  </body>
</html>
